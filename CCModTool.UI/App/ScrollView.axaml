                    <!--         </Style> -->
                    <!--     </ScrollBar.Styles> -->
                    <!-- </ScrollBar> -->
                    <ScrollBar Name="PART_VerticalScrollBar"
                               Grid.Column="1"
                               Width="8"
                               MinWidth="8"
                               MaxWidth="8"
                               HorizontalAlignment="Right"
                               AllowAutoHide="False"
                               Orientation="Vertical"
                               SmallChange="20"
                               LargeChange="120">

	                    <ScrollBar.Styles>

		                    <!-- Hide buttons safely -->
		                    <Style Selector="RepeatButton">
			                    <Setter Property="IsVisible" Value="False"/>
		                    </Style>

		                    <!-- 🔥 THIS is the real thickness control -->
		                    <Style Selector="Track">
			                    <Setter Property="Width" Value="8"/>
			                    <Setter Property="MinWidth" Value="8"/>
			                    <Setter Property="MaxWidth" Value="8"/>
		                    </Style>

		                    <!-- Thumb styling only -->
		                    <Style Selector="Thumb">
			                    <Setter Property="MinHeight" Value="40"/>
			                    <Setter Property="Width" Value="8"/>
			                    <Setter Property="Template">
				                    <ControlTemplate>
					                    <Border Background="{DynamicResource ScrollThumbColor}"
					                            CornerRadius="0"/>
				                    </ControlTemplate>
			                    </Setter>
		                    </Style>

		                    <Style Selector="Thumb:pointerover /template/ Border">
			                    <Setter Property="Background"
			                            Value="{DynamicResource ScrollThumbHoverColor}"/>
		                    </Style>

		                    <Style Selector="Thumb:pressed /template/ Border">
			                    <Setter Property="Background"
			                            Value="{DynamicResource ScrollThumbPressedColor}"/>
		                    </Style>

	                    </ScrollBar.Styles>
                    </ScrollBar>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>