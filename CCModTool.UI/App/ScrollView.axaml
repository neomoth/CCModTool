<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:CCModTool.UI.App.Behaviors"
        xmlns:converters="clr-namespace:CCModTool.UI.App.Converters"
        x:CompileBindings="False">
    <Styles.Resources>
        <converters:ScrollVisibilityConverter x:Key="ScrollVisibilityConverter"></converters:ScrollVisibilityConverter>
    </Styles.Resources>

    <Style Selector="ScrollViewer">
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="* Auto">
                    <ScrollContentPresenter Background="Transparent"
                                           Name="PART_ScrollContentPresenter"
                                           Padding="{Binding #PART_VerticalScrollBar.IsVisible, Converter={StaticResource ScrollVisibilityConverter}}"/>
                    <ScrollBar Grid.Column="0" Name="PART_HorizontalScrollBar" Orientation="Horizontal"/>
